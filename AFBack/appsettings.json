{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "REPLACE_ME"
  },
  "Jwt": {
    "Key": "REPLACE_ME",
    "Issuer": "REPLACE_ME",
    "Audience": "REPLACE_ME"
  },
  "AzureBlobStorage": {
    "ConnectionString": "REPLACE_ME"
  },
  "Serilog":
  {
    "MinimumLevel": "Debug",
    "WriteTo": [
      {"Name": "Console"}
    ,
      {
        "Name":"File",
        "Args": {
          "path": "logs/myapp.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
