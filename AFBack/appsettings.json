{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "App": {
    "BaseUrl": "https://koptr.net"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DatabaseConnection": "REPLACE_ME",
    "Redis": "REPLACE_ME"
  },
  "Cors": {
    "AllowedOrigins": ["https://koptr.net", "https://www.koptr.net"]
  },
  "ProxyRanges": [
    "NEEDS_REPLACEMENT"
  ],
  "CacheSettings": {
    "UserSummaryKeyPrefix": "user:summary:",
    "EnableCaching": true,
    "CanSendCacheDurationMinutes": 5
  },
  "Jwt": {
    "Key": "REPLACE_ME",
    "Issuer": "REPLACE_ME",
    "Audience": "REPLACE_ME"
  },
  "Storage": {
    "BlobAccountUrl": "REPLACE_ME",
    "Containers": {
      "EncryptedFiles": "REPLACE_ME",
      "PublicImages": "REPLACE_ME",
      "PrivateFiles": "REPLACE_ME"
    }
  },
  "Email": {
    "ConnectionString": "REPLACE_ME",
    "FromAddress": "DoNotReply@koptr.net",
    "SupportAddress": "support@koptr.net"
  },
  "Sms": {
    "ConnectionString": "REPLACE_ME",
    "FromNumber": "REPLACE_ME"
  },
  "KeyVault": {
    "Url": "REPLACE_ME"
  },
  "Monitoring": {
    "ApplicationInsightsConnectionString": "REPLACE_ME"
  }
}
