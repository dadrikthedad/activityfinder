{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "REPLACE_ME",
    "Redis": "REPLACE_ME"
  },
  "CacheSettings": {
    "UserSummaryKeyPrefix": "user:summary:",
    "EnableCaching": true,
    "CanSendCacheDurationMinutes": 5
  },
    "Jwt": {
    "Key": "REPLACE_ME",
    "Issuer": "REPLACE_ME",
    "Audience": "REPLACE_ME", 
    "TokenValidityMinutes": 15
  },
  "AzureBlobStorage": {
    "ConnectionString": "REPLACE_ME"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "AFBack": "Debug",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath like '/weatherforecast%'"
        }
      }
    ]
  },
  "AzureCommunication": {
    "ConnectionString": "REPLACE_ME"
  },
  "Email": {
    "FromAddress": "DoNotReply@koptr.net"
  },
  "App": {
    "BaseUrl": "https://koptr.net"
  },
  "IpBan": {
    "MaxSuspiciousAttempts": 15,
    "SuspiciousWindow": "00:10:00",
    "TemporaryBanDuration": "24:00:00",
    "NegativeCacheDuration": "00:15:00",
    "CleanupInterval": "00:30:00",
    "WhitelistedIps": [
      "127.0.0.1",
      "::1",
      "169.254.130.1"
    ]
  },
  "ProxyRanges": [
    "NEEDS_REPLACEMENT"
  ],
  "KeyVault": {
    "Url": "https://activityfinder-phrase.vault.azure.net/"
  }
}
