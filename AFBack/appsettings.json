{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "REPLACE_ME"
  },
  "Jwt": {
    "Key": "REPLACE_ME",
    "Issuer": "REPLACE_ME",
    "Audience": "REPLACE_ME"
  },
  "AzureBlobStorage": {
    "ConnectionString": "REPLACE_ME"
